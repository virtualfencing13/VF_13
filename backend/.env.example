# AI & Camera Configuration
CAMERA_SOURCE=0
CONFIDENCE_THRESHOLD=0.45
ALERT_COOLDOWN_SECONDS=10

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=your_meta_token
PHONE_NUMBER_ID=your_phone_id
RECIPIENT_PHONE=your_mobile_number

# Email (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
RECIPIENT_EMAIL=operator@facility.com

# Twilio (SMS/Call Fallback)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_PHONE=your_twilio_number
TWILIO_TO_PHONE=your_mobile_number

# Public URL (For Forensic Image Hosting)
PUBLIC_BASE_URL=http://your-public-ip-or-domain:8000
